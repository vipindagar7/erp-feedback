generator client {
  provider        = "prisma-client-js"
  output          = "../generated/prisma"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         String
  permissions  String[]
  isActive     Boolean  @default(true)
  isBlocked    Boolean  @default(false)
  isVerified   Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  students     Student?
  faculty      Faculty?
}

model Student {
  id      String @id @default(uuid())
  user_id String @unique

  // Identity
  roll_number   String  @unique
  enrollment_no String? @unique
  biometric_id  String? @unique
  group_no      String? // optional group/house number

  // Name
  name       String
  first_name String
  last_name  String

  // Personal
  dob       DateTime?
  gender    String?
  aadhar_no String?
  pan_no    String?

  // Contact
  contact_number     String
  alt_contact_number String?
  personal_email     String?

  // Parents
  father_name   String
  father_mobile String?
  mother_name   String
  mother_mobile String?

  // Admission
  mode_of_admission String?
  admission_year    Int?
  admission_date    DateTime?
  session           String?
  batch_year        Int? // year student joined the institution e.g. 2023

  // Hostel / Transport
  is_hosteller       Boolean @default(false)
  is_using_transport Boolean @default(false)

  // Local Address
  local_address         String?
  local_address_city    String?
  local_address_state   String?
  local_address_zipcode String?

  // Permanent Address
  permanent_address         String?
  permanent_address_city    String?
  permanent_address_state   String?
  permanent_address_zipcode String?

  // Current academic placement (always reflects current section)
  dept_id    String
  section_id String
  course_id  String
  program_id String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  department Department @relation(fields: [dept_id], references: [id])
  section    Section    @relation(fields: [section_id], references: [id])
  course     Course     @relation(fields: [course_id], references: [id])
  program    Program    @relation(fields: [program_id], references: [id])

  subjects           StudentSubject[]
  feedbackResponses  FeedbackResponse[]
  studentEnrollments StudentEnrollment[]
  specialGroups      SpecialGroupMember[]

  @@index([dept_id])
  @@index([section_id])
  @@index([course_id])
  @@index([program_id])
}

model Subject {
  id       String  @id @default(uuid())
  name     String
  code     String  @unique
  nickname String? // short name e.g. "DS", "DBMS"
  category String  @default("THEORY") // THEORY | PRACTICAL | TRAINING | LIBRARY | TUTORIAL | OTHER
  credits  Int     @default(4)

  createdAt DateTime @default(now())

  students        StudentSubject[]
  facultySubjects FacultySubject[]
  feedbackForms   FeedbackForm[]
  sectionSubjects SectionSubject[]
}

model StudentSubject {
  id         String @id @default(uuid())
  student_id String
  subject_id String

  student Student @relation(fields: [student_id], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([student_id, subject_id])
}

model StudentEnrollment {
  id         String @id @default(uuid())
  student_id String
  section_id String

  academic_year String
  semester      Int
  batch_year    Int    @default(0)

  dept_id    String
  course_id  String
  program_id String

  // ACTIVE | PROMOTED | DETAINED | PASSED | LEFT | TRANSFERRED
  status     String  @default("ACTIVE")
  is_current Boolean @default(false)

  enrolled_at  DateTime  @default(now())
  completed_at DateTime?
  remarks      String?

  student    Student    @relation(fields: [student_id], references: [id], onDelete: Cascade)
  section    Section    @relation(fields: [section_id], references: [id])
  department Department @relation(fields: [dept_id], references: [id])
  course     Course     @relation(fields: [course_id], references: [id])
  program    Program    @relation(fields: [program_id], references: [id])

  @@index([student_id])
  @@index([section_id])
  @@index([is_current])
  @@index([status])
  @@index([academic_year, semester])
}

model Department {
  id     String  @id @default(uuid())
  name   String  @unique
  hod_id String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  students    Student[]
  faculties   Faculty[]
  programs    Program[]
  enrollments StudentEnrollment[]

  @@index([hod_id])
}

model Program {
  id      String @id @default(uuid())
  name    String
  dept_id String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  department  Department          @relation(fields: [dept_id], references: [id], onDelete: Cascade)
  students    Student[]
  courses     Course[]
  enrollments StudentEnrollment[]

  @@index([dept_id])
}

model Course {
  id         String @id @default(uuid())
  name       String
  program_id String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  program     Program             @relation(fields: [program_id], references: [id], onDelete: Cascade)
  students    Student[]
  sections    Section[]
  enrollments StudentEnrollment[]

  @@index([program_id])
}

model Section {
  id        String @id @default(uuid())
  name      String
  course_id String
  semester  Int
  batch     String  // mandatory e.g. "2023-2027"

  class_coordinator_id String?

  course            Course   @relation(fields: [course_id], references: [id])
  class_coordinator Faculty? @relation("SectionCoordinator", fields: [class_coordinator_id], references: [id])

  students        Student[]
  enrollments     StudentEnrollment[]
  feedbackForms   FeedbackForm[]
  sectionSubjects SectionSubject[]
}

model SectionSubject {
  id         String  @id @default(uuid())
  section_id String
  subject_id String
  faculty_id String?
  type       String  @default("REGULAR") // REGULAR | ELECTIVE | COMBINED | TRAINING | OTHER
  status     String  @default("ACTIVE")  // ACTIVE | COMPLETED | REMOVED

  section Section  @relation(fields: [section_id], references: [id], onDelete: Cascade)
  subject Subject  @relation(fields: [subject_id], references: [id], onDelete: Cascade)
  faculty Faculty? @relation("SectionSubjectFaculty", fields: [faculty_id], references: [id], onDelete: SetNull)

  @@unique([section_id, subject_id])
}

model Faculty {
  id      String @id @default(uuid())
  user_id String @unique

  emp_id     String? @unique
  nick_name  String?
  first_name String
  last_name  String
  name       String

  contact_number String
  personal_email String?

  employee_type String?
  designation   String?

  dob          DateTime?
  joining_date DateTime?
  gender       String?
  religion     String?
  category     String?
  aadhar_no    String?
  pan_no       String?

  dept_id String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user       User       @relation(fields: [user_id], references: [id], onDelete: Cascade)
  department Department @relation(fields: [dept_id], references: [id])

  subjects               FacultySubject[]
  feedbackForms          FeedbackForm[]
  sectionSubjects        SectionSubject[]         @relation("SectionSubjectFaculty")
  coordinating_sections  Section[]                @relation("SectionCoordinator")
  facultyGroups          FacultyGroupMember[]

  @@index([dept_id])
}

model FacultySubject {
  id         String @id @default(uuid())
  faculty_id String
  subject_id String

  faculty Faculty @relation(fields: [faculty_id], references: [id], onDelete: Cascade)
  subject Subject @relation(fields: [subject_id], references: [id], onDelete: Cascade)

  @@unique([faculty_id, subject_id])
}

model FeedbackCategory {
  id         String   @id @default(uuid())
  name       String
  type       String
  is_active  Boolean  @default(true)
  created_by String
  createdAt  DateTime @default(now())

  questions FeedbackQuestion[]
  forms     FeedbackForm[]
  formGroups FeedbackFormGroup[]
}

model FeedbackQuestion {
  id          String   @id @default(uuid())
  category_id String
  question    String
  type        String
  options     String[]
  is_required Boolean  @default(true)
  order       Int

  category  FeedbackCategory @relation(fields: [category_id], references: [id], onDelete: Cascade)
  responses FeedbackAnswer[]
}

model FeedbackForm {
  id          String   @id @default(uuid())
  category_id String
  title       String
  is_active   Boolean  @default(true)
  start_date  DateTime
  end_date    DateTime

  faculty_id          String?
  subject_id          String?
  section_id          String?
  action_taken        String?
  group_id            String?    // keep for legacy — not used as FK
  feedbackFormGroupId String?

  category  FeedbackCategory   @relation(fields: [category_id], references: [id])
  faculty   Faculty?           @relation(fields: [faculty_id], references: [id])
  subject   Subject?           @relation(fields: [subject_id], references: [id])
  section   Section?           @relation(fields: [section_id], references: [id])
  formGroup FeedbackFormGroup? @relation(fields: [feedbackFormGroupId], references: [id], onDelete: SetNull)

  responses FeedbackResponse[]
}

model FeedbackResponse {
  id          String   @id @default(uuid())
  form_id     String
  student_id  String
  submittedAt DateTime @default(now())

  form    FeedbackForm     @relation(fields: [form_id], references: [id], onDelete: Cascade)
  student Student          @relation(fields: [student_id], references: [id], onDelete: Cascade)
  answers FeedbackAnswer[]

  @@unique([form_id, student_id])
}



model FeedbackAnswer {
  id          String  @id @default(uuid())
  response_id String
  question_id String
  answer_text String?
  rating      Int?
  selected    String?

  response FeedbackResponse @relation(fields: [response_id], references: [id], onDelete: Cascade)
  question FeedbackQuestion @relation(fields: [question_id], references: [id])

  @@unique([response_id, question_id])
}

model PasswordResetToken {
  id        String   @id @default(uuid())
  token     String   @unique
  user_id   String
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
}

// ── Special Student Groups ─────────────────────────────────────────────────────
model SpecialGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   @default("OTHER") // EVENT | SCHOLARSHIP | COMMITTEE | SPORTS | OTHER
  created_by  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members SpecialGroupMember[]

  @@index([type])
}

model SpecialGroupMember {
  id         String   @id @default(uuid())
  group_id   String
  student_id String
  addedAt    DateTime @default(now())

  group   SpecialGroup @relation(fields: [group_id],   references: [id], onDelete: Cascade)
  student Student      @relation(fields: [student_id], references: [id], onDelete: Cascade)

  @@unique([group_id, student_id])
  @@index([group_id])
  @@index([student_id])
}

// ── Faculty Groups ─────────────────────────────────────────────────────────────
model FacultyGroup {
  id          String   @id @default(uuid())
  name        String
  description String?
  type        String   @default("OTHER") // DEPARTMENT | COMMITTEE | EVENT | OTHER
  created_by  String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members FacultyGroupMember[]

  @@index([type])
}

model FacultyGroupMember {
  id         String   @id @default(uuid())
  group_id   String
  faculty_id String
  addedAt    DateTime @default(now())

  group   FacultyGroup @relation(fields: [group_id],   references: [id], onDelete: Cascade)
  faculty Faculty      @relation(fields: [faculty_id], references: [id], onDelete: Cascade)

  @@unique([group_id, faculty_id])
  @@index([group_id])
}

